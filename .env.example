# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=sherlock
DB_USER=sherlock
DB_PASSWORD=sherlock

# ── JWT Authentication ─────────────────────────────────────────────────────────
# REQUIRED in production: base64-encoded 512-bit random key.
# Generate with: openssl rand -base64 64
JWT_SECRET=

# Token lifetime in hours (default: 8 — one operator shift)
JWT_EXPIRATION_HOURS=8

# ── Frontend ───────────────────────────────────────────────────────────────────
# Cesium Ion access token (optional — free tier unlocks premium imagery/terrain)
VITE_CESIUM_TOKEN=
